{
    "name": "laragent-dev/laragent-dev",
    "description": "Autonomous AI Agents for Laravel — local LLMs or cloud, your choice",
    "keywords": ["laravel", "ai", "agents", "llm", "ollama", "anthropic", "openai", "automation"],
    "homepage": "https://laragent.dev",
    "license": "MIT",
    "authors": [
        {
            "name": "Laragent",
            "homepage": "https://laragent.dev"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/support": "^11.0",
        "illuminate/console": "^11.0",
        "illuminate/database": "^11.0",
        "illuminate/events": "^11.0",
        "illuminate/mail": "^11.0",
        "illuminate/queue": "^11.0",
        "illuminate/filesystem": "^11.0",
        "illuminate/http": "^11.0",
        "guzzlehttp/guzzle": "^7.0"
    },
    "require-dev": {
        "pestphp/pest": "^2.0",
        "pestphp/pest-plugin-laravel": "^2.0",
        "orchestra/testbench": "^9.0",
        "laravel/pint": "^1.0",
        "phpstan/phpstan": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "Laragent\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Laragent\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "./vendor/bin/pest",
        "lint": "./vendor/bin/pint"
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        },
        "sort-packages": true
    },
    "extra": {
        "laravel": {
            "providers": [
                "Laragent\\LaragentServiceProvider"
            ],
            "aliases": {
                "Agent": "Laragent\\Facades\\Agent"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
